{
  "name": "@tscircuit/eecircuit-engine",
  "version": "1.7.0",
  "description": "EEcircuit's simulation engine",
  "repository": {
    "type": "git",
    "url": "https://github.com/eelab-dev/EEcircuit-engine"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/eecircuit-engine.umd.js",
  "module": "./dist/eecircuit-engine.mjs",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/eecircuit-engine.mjs",
      "require": "./dist/eecircuit-engine.umd.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "check": "eslint . --ext .ts,.mts,.cts",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npx tsx test/run-all.ts",
    "test:source": "npx tsx test/test.ts",
    "test:package": "npx tsx test/test-package.ts",
    "test:package:psa-tps63802": "tsx test/test-package-psa-tps63802.ts",
    "test:tps63802-svg": "tsx test/test-tps63802-scope-svg.ts",
    "test:browser": "npx playwright test test/test-browser-regression.spec.mts",
    "test:browser:all": "npx playwright test test/test-browser-regression.spec.mts"
  },
  "author": "Danial Chitnis",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "eslint": "^10.1.0",
    "globals": "^17.3.0",
    "looks-same": "^9.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.2",
    "vite-plugin-dts": "^4.5.4"
  }
}
